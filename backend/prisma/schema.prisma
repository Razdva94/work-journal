generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WorkType {
  id      String         @id @default(cuid())
  name    String         @unique
  unit    String
  entries JournalEntry[]
}

model JournalEntry {
  id          String   @id @default(cuid())
  performedAt DateTime @db.Date
  workTypeId  String
  workType    WorkType @relation(fields: [workTypeId], references: [id], onDelete: Restrict)
  volume      Decimal  @db.Decimal(12, 3)
  unit        String
  workerName  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([performedAt])
}
